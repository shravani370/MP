# ═══════════════════════════════════════════════════════════════════════════
# Interview-ProAI Development Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control
#

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
# Production should use a managed PostgreSQL (AWS RDS, Heroku, Railway, etc)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://localhost/interview_proai

# For Docker Compose:
# DATABASE_URL=postgresql://interview_user:interview_password_dev@postgres:5432/interview_proai

# ─────────────────────────────────────────────────────────────────────────────
# REDIS (Cache & Session Store)
# ─────────────────────────────────────────────────────────────────────────────
# Leave empty to disable Redis (will use memory instead - not recommended for production)
REDIS_URL=redis://localhost:6379/0

# For Docker Compose:
# REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────────────────────────────────────
# FLASK SETTINGS
# ─────────────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=dev_key_change_in_production_to_long_random_string_12345678901234567890
SECURE_COOKIES=False  # Set to True in production (requires HTTPS)

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH
# ─────────────────────────────────────────────────────────────────────────────
# Create OAuth credentials at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
REDIRECT_URI=http://127.0.0.1:5000/callback
# In production: REDIRECT_URI=https://yourdomain.com/callback

# ─────────────────────────────────────────────────────────────────────────────
# AI BACKENDS
# ─────────────────────────────────────────────────────────────────────────────
# Choose ONE primary and set others as fallbacks

# OpenAI (GPT-3.5/4)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo  # or gpt-4

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-haiku-20240307  # or claude-opus

# Google Gemini
GOOGLE_API_KEY=AIzaSy...
GOOGLE_MODEL=gemini-1.5-flash

# Local Ollama (free, runs locally)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama2  # or mistral, neural-chat, etc

# ─────────────────────────────────────────────────────────────────────────────
# CELERY & ASYNC TASKS
# ─────────────────────────────────────────────────────────────────────────────
# Message broker (Redis) and result backend for Celery workers
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# For Docker Compose:
# CELERY_BROKER_URL=redis://redis:6379/1
# CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL NOTIFICATIONS (Gmail example)
# ─────────────────────────────────────────────────────────────────────────────
# Using Gmail + App Passwords (more secure than storing password)
# 1. Enable 2FA on Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate app password for "Mail"
# 4. Use that password below (not your Google account password)

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_DEFAULT_SENDER=noreply@interview-proai.com

# Alternative for Sendgrid:
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=SG.xxxxx
# MAIL_DEFAULT_SENDER=noreply@interview-proai.com

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Error Tracking (commented out - add when needed)
# ─────────────────────────────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: AWS S3 (commented out - add when needed for file uploads)
# ─────────────────────────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=interview-proai-uploads
# AWS_S3_REGION=us-east-1

# ═══════════════════════════════════════════════════════════════════════════
# QUICK START:
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Add your actual credentials
#
# 3. Start PostgreSQL (Docker Compose):
#    docker-compose up -d
#
# 4. Install dependencies:
#    pip install -r requirements.txt
#
# 5. Initialize database:
#    python -c "from app import db; db.create_all()"
#
# 6. Run the app:
#    python app.py
#
# ═══════════════════════════════════════════════════════════════════════════
