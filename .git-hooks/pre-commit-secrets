#!/bin/bash
# Pre-commit hook to prevent accidentally committing secrets
# Install: cp .git-hooks/pre-commit-secrets .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

# Patterns that should never be committed
FORBIDDEN_PATTERNS=(
    "GOCSPX-"           # Google OAuth secrets
    "sk-ant-"           # Anthropic keys
    "sk-proj-"          # OpenAI project keys
    "AIzaSy"            # Google API keys
    "SG\\..*"           # SendGrid keys
    "BEGIN RSA PRIVATE" # Private keys
    "BEGIN PRIVATE KEY" # Private keys
)

# Check for forbidden patterns in staged files
error_count=0

for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
    if git diff --cached | grep -iE "$pattern" > /dev/null; then
        echo "❌ ERROR: Attempting to commit a secret pattern: $pattern"
        error_count=$((error_count + 1))
    fi
done

# Check for specific files that should never be committed
FORBIDDEN_FILES=(
    "client_secret.json"
    "credentials.json"
    ".env"
    ".env.local"
    "*.pem"
    "*.key"
)

for file in "${FORBIDDEN_FILES[@]}"; do
    if git diff --cached --name-only | grep -E "$file"; then
        echo "❌ ERROR: Attempting to commit sensitive file: $file"
        error_count=$((error_count + 1))
    fi
done

if [ $error_count -gt 0 ]; then
    echo ""
    echo "🔐 Pre-commit security check FAILED"
    echo "Reason: Detected potential secrets or sensitive files in your commit"
    echo ""
    echo "To fix:"
    echo "1. Remove the secret from your code or .env file"
    echo "2. git reset HEAD <file>  (to unstage)"
    echo "3. Try again"
    echo ""
    echo "If you're sure this is safe, bypass with: git commit --no-verify"
    exit 1
fi

echo "✅ Pre-commit security check passed"
exit 0
